# ══════════════════════════════════════════════
# DE Senior Template — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git
# ══════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────
POSTGRES_DB=de_db
POSTGRES_USER=de_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql://de_user:CHANGE_ME@localhost:5432/de_db

# ── MinIO ──────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=CHANGE_ME_min_8_chars
MINIO_BUCKET=datalake

# ── Airflow ────────────────────────────────────
# Generate fernet key:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=CHANGE_ME_generate_with_command_above
AIRFLOW_SECRET_KEY=CHANGE_ME_random_32_char_string
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME_admin_password

# ── Alerting ───────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME

# ── Ad Platforms ───────────────────────────────
# Fill as you implement each extractor

# Facebook
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_ACCESS_TOKEN=
# FACEBOOK_AD_ACCOUNT_ID=act_XXXXXXXXX

# Google Ads
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_CUSTOMER_ID=

# TikTok
