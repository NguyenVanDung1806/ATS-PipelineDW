# ═══════════════════════════════════════════════════════════
# ATS Marketing Data Pipeline — Environment Variables
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=ats_dw
POSTGRES_USER=ats_admin
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost

# ── MinIO (S3-compatible object storage) ──────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=ats_admin
MINIO_SECRET_KEY=
MINIO_BUCKET=ats-datalake

# ── Airflow ───────────────────────────────────────────────
# Generate fernet key: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
# Generate secret key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW_SECRET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# ── Slack Alerts (optional — leave empty to disable) ──────
SLACK_WEBHOOK_URL=

# ── Ad Platform APIs (Phase 1–2) ─────────────────────────
# Facebook Ads
# FB_APP_ID=
# FB_APP_SECRET=
# FB_ACCESS_TOKEN=
# FB_AD_ACCOUNT_ID=

# Google Ads
# GG_DEVELOPER_TOKEN=
# GG_CLIENT_ID=
# GG_CLIENT_SECRET=
# GG_REFRESH_TOKEN=
# GG_CUSTOMER_ID=

# TikTok Ads
# TT_ACCESS_TOKEN=
# TT_ADVERTISER_ID=

# Zalo Ads
